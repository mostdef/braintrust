{
  "devCommand": "browser-sync start --server --port $PORT --files '*.html, *.css, *.js' --no-open --no-notify",
  "routes": [
    { "src": "/sandbox(.*)", "dest": "/404.html" },
    { "src": "/", "dest": "/movies.html" },
    { "src": "/auth/callback", "dest": "/auth-callback.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" }
  ]
}
